// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Stock {
  id          String       @id @default(cuid())
  symbol      String
  name        String
  market      String
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  monitors    Monitor[]
  kdjs        Kdj[]
  bbis        Bbi[]
  zhixingTrends ZhixingTrend[]
  quotes      Quote[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, symbol])
  @@index([userId])
  @@index([symbol])
}

model Monitor {
  id            String         @id @default(cuid())
  stockId       String
  stock         Stock          @relation(fields: [stockId], references: [id])
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  type          String        // PRICE, VOLUME, CHANGE_PERCENT, KDJ_J, WEEKLY_KDJ_J, BBI_ABOVE_CONSECUTIVE, BBI_BELOW_CONSECUTIVE, SELL_SIGNAL
  condition     String        // ABOVE, BELOW
  threshold     Float         // 阈值
  isActive      Boolean       @default(true)
  lastNotifiedAt DateTime?
  notifications Notification[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  monitorId String
  monitor   Monitor  @relation(fields: [monitorId], references: [id])
  message   String
  status    String   // PENDING, SENT, FAILED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quote {
  id            String   @id @default(cuid())
  stockId       String
  stock         Stock    @relation(fields: [stockId], references: [id])
  price         Float
  volume        Float
  changePercent Float
  dailyKdj      Kdj?    @relation("DailyKdj", fields: [dailyKdjId], references: [id])
  dailyKdjId    String?
  weeklyKdj     Kdj?    @relation("WeeklyKdj", fields: [weeklyKdjId], references: [id])
  weeklyKdjId   String?
  bbi           Bbi?    @relation(fields: [bbiId], references: [id])
  bbiId         String?
  zhixingTrend  ZhixingTrend? @relation(fields: [zhixingTrendId], references: [id])
  zhixingTrendId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([stockId])
  @@index([stockId])
  @@index([createdAt])
}

model Kdj {
  id            String       @id @default(cuid())
  stockId       String
  stock         Stock        @relation(fields: [stockId], references: [id])
  k             Float
  d             Float
  j             Float
  type          String      // DAILY or WEEKLY
  dailyQuotes   Quote[] @relation("DailyKdj")
  weeklyQuotes  Quote[] @relation("WeeklyKdj")
  date          DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([stockId, type], map: "stockId_type")
  @@index([stockId, date])
  @@index([type])
}

model Bbi {
  id                          String   @id @default(cuid())
  stockId                     String
  stock                       Stock    @relation(fields: [stockId], references: [id])
  bbi                         Float
  ma3                         Float
  ma6                         Float
  ma12                        Float
  ma24                        Float
  aboveBBIConsecutiveDays     Boolean  @default(false)
  belowBBIConsecutiveDays     Boolean  @default(false)
  aboveBBIConsecutiveDaysCount Int     @default(0)
  belowBBIConsecutiveDaysCount Int     @default(0)
  quotes                      Quote[]
  date                        DateTime @default(now())
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([stockId])
  @@index([stockId, date])
}

model ZhixingTrend {
  id                 String   @id @default(cuid())
  stockId            String
  stock              Stock    @relation(fields: [stockId], references: [id])
  whiteLine          Float
  yellowLine         Float
  previousWhiteLine  Float
  previousYellowLine Float
  isGoldenCross      Boolean  @default(false)
  isDeathCross       Boolean  @default(false)
  quotes             Quote[]
  date               DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([stockId])
  @@index([stockId, date])
}

model User {
  id                    String    @id @default(cuid())
  username              String    @unique
  name                  String?
  password              String
  role                  String    @default("USER")  // USER, ADMIN
  pushDeerKey           String?   // PushDeer 推送 key
  showBBITrendSignal    Boolean   @default(true)   // 是否显示BBI趋势信号
  buySignalJThreshold   Float     @default(20.0)   // 买入信号J值阈值
  b1NotifyEnabled       Boolean   @default(false)  // 是否开启B1全列表通知
  b1LastNotifiedAt      DateTime?
  closingScreenerEnabled         Boolean   @default(false) // 是否开启收盘选股
  closingScreenerNotifyEnabled   Boolean   @default(false) // 是否开启收盘选股通知
  closingScreenerMode            String    @default("BASIC") // BASIC, FORMULA
  closingScreenerFormula         String?   // 通达信公式
  closingScreenerMaxDailyJ       Float?    @default(20.0) // 日线J值上限
  closingScreenerMaxWeeklyJ      Float?    @default(35.0) // 周线J值上限
  closingScreenerRequirePriceAboveBBI Boolean @default(true) // 是否要求收盘价站上BBI
  closingScreenerMinAboveBBIDays Int?      @default(1) // 连续站上BBI天数下限
  closingScreenerMinVolumeRatio  Float?    @default(1.2) // 量比阈值
  closingScreenerLastNotifiedAt  DateTime?
  dataSource            String    @default("longbridge")  // longbridge, akshare
  stocks                Stock[]
  monitors              Monitor[]
  trades                TradeRecord[]
  marketScreeningResults MarketScreeningResult[]
  tdxFormulas            TdxFormula[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  sessions              Session[]
  accounts              Account[]
}

model MarketScreeningRun {
  id            String   @id @default(cuid())
  market        String
  tradeDate     DateTime
  status        String   @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  totalSymbols  Int      @default(0)
  snapshotCount Int      @default(0)
  errorMessage  String?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  snapshots     MarketScreeningSnapshot[]
  results       MarketScreeningResult[]

  @@unique([market, tradeDate])
  @@index([tradeDate])
}

model MarketScreeningSnapshot {
  id                           String   @id @default(cuid())
  runId                        String
  run                          MarketScreeningRun @relation(fields: [runId], references: [id])
  symbol                       String
  name                         String
  market                       String
  price                        Float
  changePercent                Float
  volume                       Float
  dailyK                       Float
  dailyD                       Float
  dailyJ                       Float
  weeklyJ                      Float
  bbi                          Float
  aboveBBIConsecutiveDaysCount Int
  belowBBIConsecutiveDaysCount Int
  volumeRatio                  Float
  createdAt                    DateTime @default(now())
  results                      MarketScreeningResult[]

  @@unique([runId, symbol])
  @@index([symbol])
  @@index([runId])
}

model MarketScreeningResult {
  id         String   @id @default(cuid())
  runId      String
  run        MarketScreeningRun @relation(fields: [runId], references: [id])
  snapshotId String
  snapshot   MarketScreeningSnapshot @relation(fields: [snapshotId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  symbol     String
  name       String
  reasons    String
  createdAt  DateTime @default(now())

  @@unique([runId, userId, symbol])
  @@index([userId, createdAt])
}

model TaskDefinition {
  id            String    @id @default(cuid())
  key           String    @unique
  name          String
  category      String
  schedule      String?
  isEnabled     Boolean   @default(true)
  isPaused      Boolean   @default(false)
  supportsPause Boolean   @default(true)
  supportsStop  Boolean   @default(true)
  supportsRetry Boolean   @default(true)
  maxRetries    Int       @default(3)
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastFailedAt  DateTime?
  lastStatus    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  runs          TaskRun[]

  @@index([category])
  @@index([isPaused, isEnabled])
}

model TaskRun {
  id               String         @id @default(cuid())
  taskDefinitionId String
  taskDefinition   TaskDefinition @relation(fields: [taskDefinitionId], references: [id])
  status           String         @default("PENDING")
  triggeredBy      String         @default("SYSTEM")
  runReason        String?
  retryOfRunId     String?
  retryOfRun       TaskRun?       @relation("TaskRunRetry", fields: [retryOfRunId], references: [id])
  retries          TaskRun[]      @relation("TaskRunRetry")
  startedAt        DateTime?
  finishedAt       DateTime?
  errorMessage     String?
  attempt          Int            @default(1)
  progressCurrent  Int?
  progressTotal    Int?
  progressLabel    String?
  summary          String?
  metadata         String?
  stopRequestedAt  DateTime?
  pausedAt         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  events           TaskRunEvent[]

  @@index([taskDefinitionId, createdAt])
  @@index([status, createdAt])
  @@index([retryOfRunId])
}

model TaskRunEvent {
  id        String   @id @default(cuid())
  taskRunId String
  taskRun   TaskRun  @relation(fields: [taskRunId], references: [id])
  level     String   @default("INFO")
  eventType String
  message   String
  details   String?
  createdAt DateTime @default(now())

  @@index([taskRunId, createdAt])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TradeRecord {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  symbol          String
  securityName    String?
  side            String   // BUY / SELL
  quantity        Int
  price           Float
  tradedAt        DateTime
  note            String?
  stopLossPrice   Float?
  takeProfitPrice Float?
  stopRule        String?  // whiteLine / yellowLine
  isLuZhu         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, symbol])
  @@unique([userId, symbol, side, price, quantity, tradedAt])
}

model TdxFormula {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  formula     String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

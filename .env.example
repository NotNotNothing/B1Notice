# B1Notice environment template
# 用途：
# 1) 本地开发：复制为 .env 或 .env.development
# 2) Docker 开发：复制需要的值到 .env.docker
# 3) Nixpacks / 线上：在部署平台环境变量中逐项配置

# ========================
# Runtime
# ========================
NODE_ENV="development"
DB_TYPE="sqlite"
PYTHONIOENCODING="utf-8"
NEXT_TELEMETRY_DISABLED="1"

# ========================
# Database
# 本地 / Docker SQLite 默认值
# PostgreSQL 线上请改为真实连接串
# ========================
DATABASE_URL="file:./prisma/sqlite/dev.db"
# PostgreSQL 示例：
# DATABASE_URL="postgresql://user:password@host:5432/b1notice?schema=public"
# MySQL 示例：
# DATABASE_URL="mysql://user:password@host:3306/b1notice"

# ========================
# Auth
# ========================
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ========================
# Notification
# ========================
PUSHDEER_KEY="your-pushdeer-key"

# ========================
# LongPort
# ========================
LONGPORT_APP_KEY="your-longport-app-key"
LONGPORT_APP_SECRET="your-longport-app-secret"
LONGPORT_ACCESS_TOKEN="your-longport-access-token"

# ========================
# Optional app settings
# ========================
# CLOSING_SCREENER_MAX_SYMBOLS="300"

# ========================
# Build / deploy mirrors
# Docker / Nixpacks 默认可使用镜像源；如不需要可覆盖为官方源
# ========================
NPM_CONFIG_REGISTRY="https://registry.npmmirror.com"
PIP_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
NPM_CONFIG_FETCH_RETRIES="5"
NPM_CONFIG_FETCH_RETRY_MIN_TIMEOUT="20000"
NPM_CONFIG_FETCH_RETRY_MAX_TIMEOUT="120000"
NPM_CONFIG_NETWORK_TIMEOUT="300000"

# B1Notice 开发环境 Dockerfile
# 多阶段构建，优化镜像大小和构建速度

# ========================================
# 阶段 1: 基础镜像和依赖安装
# ========================================
# 使用 Debian Slim 而不是 Alpine，因为 longport 需要 glibc
ARG NODE_IMAGE=docker.m.daocloud.io/library/node:20-slim
ARG PNPM_VERSION=10.32.1
ARG NPM_REGISTRY=https://registry.npmmirror.com
ARG PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
FROM ${NODE_IMAGE} AS base

ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0 \
    PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH \
    npm_config_registry=${NPM_REGISTRY} \
    npm_config_fetch_retries=5 \
    npm_config_fetch_retry_mintimeout=20000 \
    npm_config_fetch_retry_maxtimeout=120000 \
    npm_config_network_timeout=300000 \
    PIP_INDEX_URL=${PIP_INDEX_URL} \
    PIP_DEFAULT_TIMEOUT=120 \
    PIP_RETRIES=5

# 安装 Python 3 和构建工具（AKShare 需要）
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    build-essential \
    sqlite3 \
    postgresql-client \
    default-mysql-client \
    && rm -rf /var/lib/apt/lists/*

# 安装 Python 依赖（AKShare）
RUN pip install --no-cache-dir --break-system-packages \
    akshare \
    requests

# 设置工作目录
WORKDIR /app

# ========================================
# 阶段 2: 安装 Node.js 依赖
# ========================================
FROM base AS deps

# 复制 package 文件
COPY package.json pnpm-lock.yaml ./

# 安装固定版本 pnpm，避免 latest 漂移，也避免 corepack 绕过镜像源
RUN npm install -g pnpm@${PNPM_VERSION}

# 配置 pnpm 拉包策略，降低首次构建时的网络抖动影响
RUN pnpm config set registry ${NPM_REGISTRY} \
    && pnpm config set fetch-retries 5 \
    && pnpm config set fetch-retry-mintimeout 20000 \
    && pnpm config set fetch-retry-maxtimeout 120000 \
    && pnpm config set network-timeout 300000

# 安装依赖
RUN pnpm install --frozen-lockfile

# ========================================
# 阶段 3: 开发环境
# ========================================
FROM base AS dev

# 复制 node_modules
COPY --from=deps /app/node_modules ./node_modules

# 安装与依赖阶段一致的 pnpm 版本
RUN npm install -g pnpm@${PNPM_VERSION}

# 复制项目文件
COPY . .

# 复制环境变量
COPY .env.docker .env

# 生成 Prisma Client
RUN npx prisma generate --schema ./prisma/sqlite/schema.prisma

# 暴露端口
EXPOSE 3000

# 设置环境变量
ENV NODE_ENV=development
ENV DB_TYPE=sqlite
ENV PYTHONIOENCODING=utf-8

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3000/api/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

# 启动开发服务器
CMD ["pnpm", "run", "dev:sqlite"]

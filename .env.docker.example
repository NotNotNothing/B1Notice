# Docker development env template
# 默认被 docker-compose.yml 通过 env_file: .env.docker 加载

NODE_ENV="development"
DB_TYPE="sqlite"
DATABASE_URL="file:./prisma/sqlite/dev.db"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
PUSHDEER_KEY="your-pushdeer-key"
LONGPORT_APP_KEY="your-longport-app-key"
LONGPORT_APP_SECRET="your-longport-app-secret"
LONGPORT_ACCESS_TOKEN="your-longport-access-token"
PYTHONIOENCODING="utf-8"
NPM_CONFIG_REGISTRY="https://registry.npmmirror.com"
PIP_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
